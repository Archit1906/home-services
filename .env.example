# Server Configuration
PORT=5000

# Database Configuration (MySQL)
DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=homeconnect
DB_USER=root
DB_PASS=

# Gemini AI (Optional - local fallback exists)
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary Config (Optional - local base64 upload fallback exists)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay Config (Optional - local simulation modal fallback exists)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Frontend Firebase Configuration (Optional - local storage auth fallback exists)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Google Maps (Optional - local interactive map simulation fallback exists)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
